---
import BaseLayout from "../layouts/BaseLayout.astro";
import AnnouncementBar from "../components/announcement-bar/AnnouncementBar.astro";
import Topbar from "../components/topbar/Topbar.astro";
import Hero from "../sections/hero/Hero.astro";
import Modalities from "../sections/modalities/Modalities.astro";
import Testimonials from "../sections/testimonials/Testimonials.astro";
import CTA from "../sections/cta/CTA.astro";
import Footer from "../sections/footer/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import EnrollmentLetter from "../components/enrollment-letter/EnrollmentLetter.tsx";

const displayAnnouncementBar = true;
---

<style>
	:global(body) {
		position: relative;
	}

	:global(body)::before {
		content: "";
		position: fixed;
		inset: 0;
		/* dotted bg */
		background-image: radial-gradient(
			rgba(0, 0, 0, 0.1) 1px,
			transparent 1px
		);
		background-size: 12px 12px;
		z-index: 1;
		pointer-events: none;
	}

	:global(body) {
		background-color: #f4f4f4 !important;
	}
</style>

<BaseLayout
	seo={{
		title: "Idiomas Para Todos",
		description:
			"Domine a fluência com a Rise Idiomas. Oferecemos cursos de inglês, espanhol e português desenvolvidos estrategicamente para o seu sucesso no nível executivo, tech, na vida acadêmica e em certificações internacionais.",
		type: "website",
		image: "/favicon.svg",
	}}
>
	<Fragment slot="head">
		<!-- Google Knowledge Graph / Rich Snippets (Structured Data) -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "EducationalOrganization",
				name: "Rise Idiomas",
				description:
					"Escola de inglês moderna e imersiva focada no ensino de alta performance para adolescentes, executivos e mercado jurídico.",
				logo: new URL("/favicon.svg", Astro.url).toString(),
				url: Astro.url.origin,
				offers: [
					{
						"@type": "Course",
						name: "Inglês Executivo",
						description:
							"Foco em nuances culturais, diplomacia corporativa e técnicas de persuasão em inglês avançado.",
					},
					{
						"@type": "Course",
						name: "Inglês Acadêmico",
						description:
							"Linguagem técnica, produção de artigos e leitura em nível de excelência.",
					},
					{
						"@type": "Course",
						name: "Inglês Jurídico",
						description:
							"Terminologia essencial, interpretação de contratos e comunicação assertiva no Direito Internacional.",
					},
				],
			})}
		/>
	</Fragment>
	<div class="w-full min-h-screen relative">
		{
			displayAnnouncementBar && (
				<AnnouncementBar
					text="🎓Turmas abertas para 2026! Não perca a oportunidade de estudar conosco📚"
					link="#"
				/>
			)
		}
		<Topbar />

		<main
			class="relative flex flex-col gap-26 md:gap-32 lg:gap-20 overflow-x-hidden w-full max-w-[100vw]"
		>
			<Hero />
			<Modalities />
			<Testimonials />
			<div class="flex justify-center pointer-events-none">
				<!-- only executes this island when the user scrolls to it -->
				<EnrollmentLetter client:visible />
			</div>
			<CTA />
			<Footer />
		</main>
	</div>
	<Analytics />
</BaseLayout>
