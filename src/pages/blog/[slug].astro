---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RiseLogo from "../../assets/shared/rise-logo.svg";
import type { BlogPost } from "../../types/blog";
import type { SanityPortableBodyNode, SanityPortableTextBlock } from "../../lib/sanity.types";
import { getBlogPostBySlug, getBlogSlugs } from "../../lib/sanity.blog";
import PortableRichContent from "../../components/blog/portable/PortableRichContent.astro";

export async function getStaticPaths() {
  const slugs = await getBlogSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

type TocLevel = "h2" | "h3" | "h4";

interface ArticleTocItem {
  id: string;
  label: string;
  level: TocLevel;
}

function slugifyHeadingValue(value: string): string {
  return value
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "")
    .slice(0, 96);
}

function extractPortableHeadingLabel(block: SanityPortableTextBlock): string {
  return (block.children || [])
    .map((child) => child.text || "")
    .join("")
    .replace(/\s+/g, " ")
    .trim();
}

function resolvePortableHeadingId(block: SanityPortableTextBlock, label: string): string {
  const normalizedKey = block._key ? slugifyHeadingValue(block._key) : "";
  if (normalizedKey) {
    return `pt-h-${normalizedKey}`;
  }

  const normalizedLabel = slugifyHeadingValue(label);
  return normalizedLabel || "pt-heading";
}

function buildBodyTocItems(body: SanityPortableBodyNode[] | undefined): ArticleTocItem[] {
  if (!Array.isArray(body) || body.length === 0) {
    return [];
  }

  let fallbackIndex = 0;

  return body.flatMap((node) => {
    if (node._type !== "block") {
      return [];
    }

    const level = node.style;
    if (level !== "h2" && level !== "h3" && level !== "h4") {
      return [];
    }

    const label = extractPortableHeadingLabel(node);
    if (!label) {
      return [];
    }

    const id = resolvePortableHeadingId(node, label) || `pt-heading-${++fallbackIndex}`;
    return [{ id, label, level } satisfies ArticleTocItem];
  });
}

const { slug } = Astro.params;
const {
  post,
  relatedPosts,
  errorMessage: blogErrorMessage,
} = slug
  ? await getBlogPostBySlug(slug)
  : {
      post: undefined,
      relatedPosts: [],
      errorMessage: null,
    };

if (!post) {
  return Astro.redirect("/404");
}

const currentPost: BlogPost = post;
const titleLines =
  currentPost.titleLines && currentPost.titleLines.length > 0
    ? currentPost.titleLines
    : [currentPost.title];
const hasPortableBody = Boolean(currentPost.portableBody && currentPost.portableBody.length > 0);
const hasLegacySections = currentPost.sections.length > 0;
const hasSectionNavigation = hasLegacySections && !hasPortableBody;
const bodyTocItems = hasPortableBody ? buildBodyTocItems(currentPost.portableBody || []) : [];
const legacyTocItems: ArticleTocItem[] = hasSectionNavigation
  ? currentPost.sections.map((section) => ({
      id: section.id,
      label: section.tocLabel,
      level: "h2",
    }))
  : [];
const tocItems = hasPortableBody ? bodyTocItems : legacyTocItems;
const hasToc = tocItems.length > 0;
const summaryPoints = (currentPost.summaryPoints || []).filter(Boolean);
const hasHeroImage = Boolean(currentPost.heroImage?.url);
const heroImageAlt = currentPost.heroImage?.alt || `Imagem do post ${currentPost.title}`;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(
  Astro.url.href,
)}`;
const articleImageUrl = new URL(currentPost.seoImage || "/favicon.svg", Astro.url).toString();
const articleTags = currentPost.tags.slice(0, 6);
const articlePublishedIso = `${currentPost.publishDate}T00:00:00.000Z`;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: currentPost.title,
  description: currentPost.seoDescription || currentPost.excerpt,
  image: [articleImageUrl],
  datePublished: articlePublishedIso,
  dateModified: articlePublishedIso,
  author: {
    "@type": "Person",
    name: currentPost.author.name,
  },
  publisher: {
    "@type": "Organization",
    name: "Rise Idiomas",
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.svg", Astro.url).toString(),
    },
  },
  mainEntityOfPage: Astro.url.href,
  articleSection: currentPost.category,
  keywords: currentPost.tags.join(", "),
  wordCount: Math.max(currentPost.readingTimeMinutes * 200, 200),
});
---

<BaseLayout
  seo={{
    title: currentPost.seoTitle || currentPost.title,
    description: currentPost.seoDescription || currentPost.excerpt,
    type: "article",
    image: currentPost.seoImage || "/favicon.svg",
    canonicalUrl: currentPost.canonicalUrl,
  }}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <meta property="article:published_time" content={articlePublishedIso} />
    <meta property="og:article:published_time" content={articlePublishedIso} />
    <meta property="article:section" content={currentPost.category} />
    <meta property="og:article:section" content={currentPost.category} />
    <meta property="article:author" content={currentPost.author.name} />
    {
      articleTags.map((tag) => (
        <Fragment>
          <meta property="article:tag" content={tag} />
          <meta property="og:article:tag" content={tag} />
        </Fragment>
      ))
    }
    {currentPost.noIndex && <meta name="robots" content="noindex, nofollow" />}
    <script type="application/ld+json" set:html={articleJsonLd}></script>
  </Fragment>

  <div class="blog-shell">
    <div id="blog-progress" aria-hidden="true"></div>

    <header class="topbar">
      <a href="/" class="t-logo" aria-label="Ir para pagina inicial">
        <img src={RiseLogo.src} alt="Rise Idiomas" width="82" height="40" />
      </a>
      <a href="/blog" class="t-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M12 7H2M2 7L6 3M2 7L6 11"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
        Blog
      </a>
    </header>

    <article>
      {
        blogErrorMessage && (
          <p class="blog-alert" role="status">
            {blogErrorMessage} Verifique a configuracao do Sanity e tente novamente.
          </p>
        )
      }

      <header class="art-header">
        <div class="ah-left">
          <div class="ah-meta">
            <span class="ah-tag">{currentPost.category}</span>
            <span class="ah-date">{currentPost.publishDateLabel}</span>
            <span class="ah-dot">·</span>
            <span class="ah-read">{currentPost.readingTimeMinutes} min de leitura</span>
          </div>

          <h1 class="ah-title">
            {titleLines.map((line) => (
              <span class="ah-title-row"><span class="ah-title-inner">{line}</span></span>
            ))}
          </h1>
        </div>

        <div class="ah-vr" aria-hidden="true"></div>

        <div class="ah-right">
          <div class="ah-author">
            <div class="ah-avatar">{currentPost.author.initials}</div>
            <div class="ah-author-info">
              <div class="ah-author-name">{currentPost.author.name}</div>
              <div class="ah-author-role">{currentPost.author.role}</div>
            </div>
          </div>

          <div class="ah-share">
            <span class="ah-share-label">Compartilhar</span>
            <a
              href={linkedInShareUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              aria-label="Compartilhar no LinkedIn"
            >
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                <rect x="1" y="1" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1"></rect>
                <path d="M4 9V6M4 4.5V5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
                <path
                  d="M7 9V7a1.5 1.5 0 013 0v2M7 6v3"
                  stroke="currentColor"
                  stroke-width="1.1"
                  stroke-linecap="round"
                ></path>
              </svg>
            </a>
            <button id="copy-link-button" class="share-btn" aria-label="Copiar link do artigo">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                <path
                  d="M5 7.5a3 3 0 004.243.243l1.5-1.5a3 3 0 00-4.243-4.243L5.5 3"
                  stroke="currentColor"
                  stroke-width="1.1"
                  stroke-linecap="round"
                ></path>
                <path
                  d="M8 5.5a3 3 0 00-4.243-.243L2.257 6.757a3 3 0 004.243 4.243L7.5 10"
                  stroke="currentColor"
                  stroke-width="1.1"
                  stroke-linecap="round"
                ></path>
              </svg>
            </button>
          </div>
          <p id="copy-link-feedback" class="copy-feedback" aria-live="polite"></p>
        </div>
      </header>

      <div class="art-hero">
        {
          hasHeroImage ? (
            <img
              class="art-hero-image"
              src={currentPost.heroImage?.url}
              alt={heroImageAlt}
              width={currentPost.heroImage?.width}
              height={currentPost.heroImage?.height}
              loading="eager"
              decoding="async"
            />
          ) : (
            <>
              <div class="art-hero-ghost" aria-hidden="true">{currentPost.heroGhostWord || "FALAR"}</div>
              <svg viewBox="0 0 520 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ilustracao sobre speaking e fluencia">
                <path d="M100 140 C100 80 148 40 200 40 C220 40 238 48 252 62 L252 218 C238 232 220 240 200 240 C148 240 100 200 100 140Z" fill="#E8E6DF" stroke="rgba(17,17,32,.1)" stroke-width="1"></path>
                <path d="M130 100 C138 90 152 92 158 102" stroke="rgba(17,17,32,.12)" stroke-width="1.2" fill="none"></path>
                <path d="M120 130 C132 118 148 122 152 134" stroke="rgba(17,17,32,.1)" stroke-width="1.2" fill="none"></path>
                <path d="M132 162 C144 150 162 154 164 168" stroke="rgba(17,17,32,.1)" stroke-width="1.2" fill="none"></path>
                <path d="M140 192 C154 180 172 184 172 198" stroke="rgba(17,17,32,.08)" stroke-width="1.2" fill="none"></path>
                <path d="M252 62 C266 48 284 40 304 40 C356 40 404 80 404 140 C404 200 356 240 304 240 C284 240 266 232 252 218 Z" fill="#2B2BA8" opacity=".12" stroke="rgba(43,43,168,.25)" stroke-width="1"></path>
                <path d="M280 100 C288 90 302 92 308 102" stroke="rgba(43,43,168,.3)" stroke-width="1.2" fill="none"></path>
                <path d="M300 128 C312 116 328 120 332 132" stroke="rgba(43,43,168,.25)" stroke-width="1.2" fill="none"></path>
                <path d="M290 162 C302 150 320 154 322 168" stroke="rgba(43,43,168,.2)" stroke-width="1.2" fill="none"></path>
                <line x1="252" y1="32" x2="252" y2="248" stroke="rgba(17,17,32,.3)" stroke-width="1.5" stroke-dasharray="5 4"></line>
                <text x="176" y="268" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" fill="#8A8A9E" letter-spacing="2">ENTENDE</text>
                <text x="328" y="268" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" fill="#2B2BA8" letter-spacing="2">PRODUZ?</text>
                <rect x="239" y="120" width="26" height="20" rx="3" fill="white" stroke="rgba(17,17,32,.2)" stroke-width="1"></rect>
                <path d="M244 120 C244 111 260 111 260 120" stroke="rgba(17,17,32,.2)" stroke-width="1.2" fill="none"></path>
                <circle cx="252" cy="130" r="3" fill="rgba(17,17,32,.25)"></circle>
                <path d="M420 110 C432 124 432 156 420 170" stroke="rgba(43,43,168,.3)" stroke-width="1.5" fill="none"></path>
                <path d="M428 98 C446 116 446 164 428 182" stroke="rgba(43,43,168,.2)" stroke-width="1.2" fill="none"></path>
                <path d="M80 136 C80 128 88 128 88 136 C88 144 80 144 80 136Z" stroke="rgba(17,17,32,.2)" stroke-width="1" fill="none"></path>
                <line x1="76" y1="132" x2="92" y2="140" stroke="rgba(17,17,32,.25)" stroke-width="1.2"></line>
              </svg>
            </>
          )
        }
      </div>

      <div class={`art-body-wrap ${hasSectionNavigation ? "" : "art-body-wrap-no-sections"}`}>
        {
          hasSectionNavigation && (
            <div class="art-rail" aria-hidden="true">
              {
                currentPost.sections.map((section, index) => (
                  <div class="rail-num" id={`rn-${section.id}`}>{String(index + 1).padStart(2, "0")}</div>
                ))
              }
            </div>
          )
        }

        <div class="art-prose" id="prose">
          <p class="lead">{currentPost.lead}</p>

          {
            summaryPoints.length > 0 && (
              <ul class="summary-points">
                {summaryPoints.map((point) => <li>{point}</li>)}
              </ul>
            )
          }

          {
            hasPortableBody ? (
              <PortableRichContent body={currentPost.portableBody || []} />
            ) : (
              currentPost.sections.map((section) => (
                <section id={section.id}>
                  <h2 set:html={section.headingHtml}></h2>
                  {
                    section.blocks.map((block) => {
                      if (block.type === "paragraph") {
                        return <Fragment set:html={block.content}></Fragment>;
                      }

                      if (block.type === "subheading") {
                        return <h3>{block.content}</h3>;
                      }

                      if (block.type === "callout") {
                        return (
                          <div class="callout">
                            <div class="callout-label">{block.label}</div>
                            <div class="callout-content" set:html={block.content}></div>
                          </div>
                        );
                      }

                      if (block.type === "pullquote") {
                        return (
                          <div class="pullquote">
                            <div class="pq-text">{block.quote}</div>
                            <div class="pq-attr">{block.attribution}</div>
                          </div>
                        );
                      }

                      if (block.type === "numbered-list") {
                        return (
                          <ol>
                            {
                              block.items.map((item, itemIndex) => (
                                <li>
                                  <span class="li-num">{String(itemIndex + 1).padStart(2, "0")}</span>
                                  <span>
                                    <strong>{item.title}</strong> {item.description}
                                  </span>
                                </li>
                              ))
                            }
                          </ol>
                        );
                      }

                      return <hr class="art-rule" />;
                    })
                  }
                </section>
              ))
            )
          }

          <div class="art-tags">
            <span class="art-tags-label">Tags</span>
            {currentPost.tags.map((tag) => <a class="atag" href={`/blog?tag=${encodeURIComponent(tag)}`}>{tag}</a>)}
          </div>
        </div>

        <aside class="art-sidebar">
          {
            hasToc && (
              <>
                <div class="toc-label">Neste artigo</div>
                <ul class="toc-list">
                  {
                    tocItems.map((item, index) => (
                      <li class="toc-item">
                        <a
                          href={`#${item.id}`}
                          class={`toc-link toc-level-${item.level} ${index === 0 ? "active" : ""}`}
                        >
                          <span class="toc-n">{String(index + 1).padStart(2, "0")}</span>
                          {item.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </>
            )
          }

          <div class="sb-cta">
            <div class="sb-cta-label">{currentPost.sidebarCta.label}</div>
            <p class="sb-cta-text">{currentPost.sidebarCta.text}</p>
            <a href={currentPost.sidebarCta.buttonUrl} class="sb-cta-btn">
              <span>{currentPost.sidebarCta.buttonText} -></span>
            </a>
          </div>

          <div class="sb-rel-label">Leia tambem</div>
          {
            relatedPosts.map((relatedPost) => (
              <a class="sb-rel-item" href={`/blog/${relatedPost.slug}`}>
                <div class="sb-rel-tag">{relatedPost.category}</div>
                <div class="sb-rel-title">{relatedPost.title}</div>
              </a>
            ))
          }
        </aside>
      </div>

      <div class="author-bio">
        <div class="bio-left">
          <div class="bio-avatar">{currentPost.author.initials}</div>
          <div>
            <div class="bio-name">{currentPost.author.name}</div>
            <div class="bio-role">{currentPost.author.role}</div>
            <p class="bio-text">{currentPost.author.bio}</p>
          </div>
        </div>

        <div class="bio-vr" aria-hidden="true"></div>

        <div class="bio-right">
          <div class="bio-cta-label">Pronto para o proximo nivel?</div>
          <div class="bio-cta-hl">
            De o <span class="a">salto</span> que voce merece.
          </div>
          <a href="https://wa.me/5511948606841" class="bio-btn" target="_blank" rel="noopener noreferrer">
            Fale conosco
            <span class="bio-arr">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path
                  d="M2 10L10 2M10 2H4.5M10 2V7.5"
                  stroke="white"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <div class="foot-bar">
        {
          currentPost.footerStats.map((stat) => (
            <div class="fb">
              <span class="fb-l">{stat.label}</span>
              <span class="fb-v" set:html={stat.valueHtml}></span>
            </div>
          ))
        }
      </div>
    </article>
  </div>

  <script is:inline>
    (() => {
      const progressBar = document.getElementById("blog-progress");
      const tocLinks = Array.from(document.querySelectorAll(".toc-link"));
      const railNumbers = Array.from(document.querySelectorAll(".rail-num"));

      const sectionElements = tocLinks
        .map((link) => {
          const href = link.getAttribute("href");
          if (!href || !href.startsWith("#")) {
            return null;
          }
          return document.getElementById(href.slice(1));
        })
        .filter((section) => Boolean(section));

      const updateProgress = () => {
        if (!progressBar) {
          return;
        }
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollHeight > 0 ? (window.scrollY / scrollHeight) * 100 : 0;
        progressBar.style.width = progress + "%";
      };

      const setActive = (activeIndex) => {
        tocLinks.forEach((link, index) => {
          link.classList.toggle("active", index === activeIndex);
        });

        railNumbers.forEach((railNumber, index) => {
          railNumber.classList.toggle("vis", index <= activeIndex);
          railNumber.classList.toggle("cur", index === activeIndex);
        });
      };

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }

            const sectionIndex = sectionElements.indexOf(entry.target);
            if (sectionIndex >= 0) {
              setActive(sectionIndex);
            }
          });
        },
        {
          threshold: 0.3,
          rootMargin: "-80px 0px -42% 0px",
        },
      );

      sectionElements.forEach((section) => {
        sectionObserver.observe(section);
      });

      tocLinks.forEach((link, index) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const target = sectionElements[index];
          if (!target) {
            return;
          }
          target.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        });
      });

      const revealTargets = document.querySelectorAll(
        ".art-prose h2, .art-prose h3, .art-prose p, .callout, .pullquote, .art-prose ol, .art-rule, .portable-heading, .portable-paragraph, .portable-callout, .portable-code-block, .portable-table-wrap, .portable-embed, .portable-image, .portable-blockquote, .portable-list-bullet, .portable-list-number",
      );

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.1 },
      );

      revealTargets.forEach((target) => {
        if (target.classList.contains("lead")) {
          return;
        }
        target.classList.add("reveal-item");
        revealObserver.observe(target);
      });

      const copyButton = document.getElementById("copy-link-button");
      const copyFeedback = document.getElementById("copy-link-feedback");

      const showCopyFeedback = (message) => {
        if (!copyFeedback) {
          return;
        }
        copyFeedback.textContent = message;
        window.setTimeout(() => {
          copyFeedback.textContent = "";
        }, 2000);
      };

      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          try {
            if (navigator.clipboard && window.isSecureContext) {
              await navigator.clipboard.writeText(window.location.href);
              showCopyFeedback("Link copiado.");
              return;
            }
            window.prompt("Copie o link do artigo:", window.location.href);
            showCopyFeedback("Link pronto para copia.");
          } catch {
            window.prompt("Copie o link do artigo:", window.location.href);
            showCopyFeedback("Nao foi possivel copiar automaticamente.");
          }
        });
      }

      setActive(0);
      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
    })();
  </script>
</BaseLayout>

<style>
  :root {
    --cream: #f6f4ef;
    --ink: #111120;
    --blue: #2b2ba8;
    --mid: #8a8a9e;
    --rule: rgba(17, 17, 32, 0.1);
    --rule-strong: rgba(17, 17, 32, 0.2);
  }

  :global(html),
  :global(body) {
    max-width: 100%;
    overflow-x: hidden;
  }

  .blog-shell {
    background: var(--cream);
    color: var(--ink);
    width: 100%;
    overflow-x: hidden;
  }

  article {
    max-width: 100%;
    overflow-x: hidden;
  }

  .blog-alert {
    margin: 20px 44px 0;
    border: 1px solid var(--rule-strong);
    background: rgba(17, 17, 32, 0.04);
    padding: 12px 14px;
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: var(--mid);
  }

  #blog-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--blue);
    z-index: 200;
    transition: width 120ms linear;
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 44px;
    background: rgba(246, 244, 239, 0.93);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
  }

  .t-logo {
    display: inline-flex;
    align-items: center;
  }

  .t-logo img {
    width: 82px;
