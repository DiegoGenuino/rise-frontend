---
import { Image } from "astro:assets";
import Glass from "../glass/Glass.astro";
import ModalityPanelOverlay from "./ModalityPanelOverlay.astro";

// Props for flexible modality panel
export interface Props {
  title: string;
  subtitle: string;
  description: string;
  buttonLabel?: string;
  modalityId?: string; // used to identify the which overlay to show
  overlayFeatures?: string[];
  overlayTagline?: string;
  overlayDescription?: string;
  images: Array<{
    src: any; // Astro ImageMetadata
    alt: string;
    class?: string;
    animation?: string; // CSS animation class or keyframes
    loading?: "lazy" | "eager";
    style?: string;
    widths?: number[];
    sizes?: string;
    data?: Record<string, boolean | string>; // For dataset properties
  }>;
  titleClass?: string;
  descriptionClass?: string;
  panelClass?: string;
  contentClass?: string;
  imageContainerClass?: string;
  buttonClass?: string;
  customStyles?: string;
}

const {
  title,
  subtitle,
  description,
  buttonLabel = "Saiba Mais",
  modalityId,
  overlayFeatures,
  overlayTagline,
  overlayDescription,
  images,
  titleClass = "title text-5xl sm:text-6xl lg:text-7xl font-bold text-[#28286F] leading-tight",
  descriptionClass = "text-xl sm:text-2xl text-[#2A2286]/95 leading-relaxed max-w-xl",
  panelClass = "grid lg:grid-cols-2 gap-12 items-center h-full",
  contentClass = "flex flex-col gap-4 md:items-center md:text-center lg:items-start lg:text-left",
  imageContainerClass = "flex justify-center lg:justify-end",
  customStyles,
} = Astro.props;

const hasOverlay = modalityId && overlayFeatures && overlayFeatures.length > 0;
---

{customStyles && <style set:html={customStyles} />}

<div class={panelClass}>
  <div class={contentClass}>
    <p class="text-base font-light tracking-widest uppercase text-gray-400">
      {title}
    </p>
    <h2 class={titleClass} set:html={subtitle} />
    <p class={descriptionClass} set:html={description} />
    {
      buttonLabel && (
        <div class="hidden lg:block">
          <button
            class="liquid-glass-btn-pure px-12 py-4 font-bold text-lg tracking-wide flex items-center justify-center outline-none w-fit mt-8"
            data-saiba-mais
          >
            <span class="relative z-10">{buttonLabel}</span>
          </button>
        </div>
      )
    }
  </div>
  <div class={imageContainerClass}>
    <div class="relative w-full max-w-md h-80 sm:h-96">
      {
        images.map((image) => {
          // Build data attributes dynamically if passed
          const dataAttrs = image.data
            ? Object.fromEntries(
                Object.entries(image.data).map(([key, val]) => [
                  `data-${key}`,
                  val,
                ]),
              )
            : {};

          return (
            <Image
              src={image.src}
              alt={image.alt}
              class={
                image.class ?? "w-full h-full object-contain drop-shadow-2xl"
              }
              loading={image.loading ?? "lazy"}
              widths={image.widths}
              sizes={image.sizes}
              style={image.style}
              {...(image.animation
                ? { "data-animation": image.animation }
                : {})}
              {...dataAttrs}
            />
          );
        })
      }
      <slot name="image-overlay" />
    </div>
  </div>

  <!-- Mobile Button positioned at the bottom of the panel -->
  <div class="w-full flex justify-center lg:hidden mt-2 p-4">
    <button
      class="liquid-glass-btn-pure px-12 py-4 font-bold text-lg tracking-wide flex items-center justify-center outline-none"
      data-saiba-mais
    >
      <span class="relative z-10">{buttonLabel}</span>
    </button>
  </div>
</div>

{/* Overlay rendered as child of ModalityPanel */}
{
  hasOverlay && (
    <ModalityPanelOverlay
      modalityId={modalityId}
      title={title}
      tagline={overlayTagline || subtitle}
      description={overlayDescription}
      features={overlayFeatures}
    />
  )
}

<!-- 'saiba mais' button style -->
<style>
  .liquid-glass-btn-pure {
    position: relative;
    background: transparent;
    backdrop-filter: blur(0.3px);
    /* Floating outer shadow */
    box-shadow: 0 4px 12px rgba(30, 30, 80, 0.123);

    /* Highly rounded corners for the shadow shape */
    border-radius: 9999px;
    font-weight: 400;
    color: #28286f;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Hover state */
  .liquid-glass-btn-pure:hover {
    box-shadow: 0 8px 24px rgba(30, 30, 80, 0.1);
    transform: translateY(-2px);
  }

  /* Active state */
  .liquid-glass-btn-pure:active {
    box-shadow: 0 2px 8px rgba(30, 30, 80, 0.05);
    transform: translateY(1px);
  }
</style>
