---
import { Image } from "astro:assets";
import Glass from "../glass/Glass.astro";

// Props for flexible modality panel
export interface Props {
  title: string;
  subtitle: string;
  description: string;
  buttonLabel?: string;
  buttonOnClick?: string;
  images: Array<{
    src: any; // Astro ImageMetadata
    alt: string;
    class?: string;
    animation?: string; // CSS animation class or keyframes
    loading?: "lazy" | "eager";
    style?: string;
    widths?: number[];
    sizes?: string;
    data?: Record<string, boolean | string>; // For dataset properties
  }>;
  titleClass?: string;
  descriptionClass?: string;
  panelClass?: string;
  contentClass?: string;
  imageContainerClass?: string;
  buttonClass?: string;
  customStyles?: string;
}

const {
  title,
  subtitle,
  description,
  buttonLabel = "Saiba Mais",
  buttonOnClick,
  images,
  titleClass = "title text-5xl sm:text-6xl lg:text-7xl font-bold text-[#28286F] leading-tight",
  descriptionClass = "text-xl sm:text-2xl text-[#2A2286]/95 leading-relaxed max-w-xl",
  panelClass = "grid lg:grid-cols-2 gap-12 items-center h-full",
  contentClass = "flex flex-col gap-4 md:items-center md:text-center lg:items-start lg:text-left",
  imageContainerClass = "flex justify-center lg:justify-end",
  customStyles,
} = Astro.props;
---

{customStyles && <style set:html={customStyles} />}

<!-- 'saiba mais' button style -->
<style>
  .liquid-glass-btn-pure {
    position: relative;
    /* Translucent bg with radial highlighting to simulate surface tension */
    background: radial-gradient(
      150% 150% at 50% 0%,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.05) 100%
    );

    /* Real glass distortion */
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);

    /* Faint white border with low opacity */
    border: 1px solid rgba(255, 255, 255, 0.35);

    /* Inner highlight at top, inner shading at bottom + Soft outer shadow floating depth */
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.4),
      inset 0 -2px 6px rgba(0, 0, 0, 0.05),
      0 12px 32px rgba(30, 30, 80, 0.15);

    /* Highly rounded corners */
    border-radius: 9999px;

    color: #28286f;
    overflow: hidden;
    isolation: isolate;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Simulate volumetric liquid highlight */
  .liquid-glass-btn-pure::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(255, 255, 255, 0.45) 0%,
      rgba(255, 255, 255, 0) 50%
    );
    pointer-events: none;
    z-index: -1;
  }

  /* Hover state constraints */
  .liquid-glass-btn-pure:hover {
    filter: brightness(1.08); /* Increase brightness slightly */
    backdrop-filter: blur(16px) saturate(180%); /* Increase blur subtly */
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    box-shadow:
      inset 0 3px 6px rgba(255, 255, 255, 0.8),
      inset 0 -2px 6px rgba(0, 0, 0, 0.05),
      0 16px 40px rgba(30, 30, 80, 0.2),
      0 0 24px rgba(255, 255, 255, 0.5); /* Soft glow around button */
    transform: translateY(-2px);
  }

  /* Active state soft press */
  .liquid-glass-btn-pure:active {
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.5),
      inset 0 -1px 3px rgba(0, 0, 0, 0.05),
      0 6px 16px rgba(30, 30, 80, 0.1); /* Reduce shadow slightly */
    transform: translateY(1px);
  }
</style>

<div class={panelClass}>
  <div class={contentClass}>
    <p class="text-base font-light tracking-widest uppercase text-gray-400">
      {title}
    </p>
    <h2 class={titleClass} set:html={subtitle} />
    <p class={descriptionClass} set:html={description} />
    {
      buttonLabel && (
        <div class="hidden lg:block">
          <button
            class="liquid-glass-btn-pure px-12 py-4 font-bold text-lg tracking-wide flex items-center justify-center outline-none w-fit"
            onclick={buttonOnClick}
          >
            <span class="relative z-10">{buttonLabel}</span>
          </button>
        </div>
      )
    }
  </div>
  <div class={imageContainerClass}>
    <div class="relative w-full max-w-md h-80 sm:h-96">
      {
        images.map((image) => {
          // Build data attributes dynamically if passed
          const dataAttrs = image.data
            ? Object.fromEntries(
                Object.entries(image.data).map(([key, val]) => [
                  `data-${key}`,
                  val,
                ]),
              )
            : {};

          return (
            <Image
              src={image.src}
              alt={image.alt}
              class={
                image.class ?? "w-full h-full object-contain drop-shadow-2xl"
              }
              loading={image.loading ?? "lazy"}
              widths={image.widths}
              sizes={image.sizes}
              style={image.style}
              {...(image.animation
                ? { "data-animation": image.animation }
                : {})}
              {...dataAttrs}
            />
          );
        })
      }
      <slot name="image-overlay" />
    </div>
  </div>

  <!-- Mobile Button positioned at the bottom of the panel -->
  <div class="w-full flex justify-center lg:hidden mt-2 p-4">
    <button
      class="liquid-glass-btn-pure px-12 py-4 font-bold text-lg tracking-wide flex items-center justify-center outline-none"
      onclick={buttonOnClick}
    >
      <span class="relative z-10">{buttonLabel}</span>
    </button>
  </div>
</div>
