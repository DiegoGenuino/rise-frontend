---
interface Props {
  modalityId: string;
  title: string;
  tagline: string;
  description?: string;
  features: string[];
  cta?: string;
  ctaLink?: string;
}

const {
  modalityId,
  title,
  tagline,
  description,
  features,
  cta = "Agende uma aula experimental",
  ctaLink = "/contato",
} = Astro.props;
---

<!-- Modality Detail Overlay -->
<div
  class="modality-overlay fixed inset-0 z-50"
  data-modality-overlay={modalityId}
  role="dialog"
  aria-modal="true"
  aria-label={`Detalhes - ${title}`}
>
  <!-- Close Button -->
  <button
    class="overlay-close absolute top-[13px] right-4 md:top-8 md:right-12 z-50 cursor-pointer"
    data-overlay-close
    aria-label="Fechar detalhes"
  >
    <svg
      width="32"
      height="32"
      viewBox="0 0 24 24"
      fill="none"
      stroke="#4242A5"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Content — floats directly on frosted glass, no card -->
  <div class="overlay-body">
    <!-- Tag -->
    <div class="overlay-item" style="--i: 0">
      <span class="overlay-tag">{modalityId.toUpperCase()}</span>
    </div>

    <!-- Title -->
    <div class="overlay-item" style="--i: 1">
      <h2 class="overlay-title">{title}</h2>
    </div>

    <!-- Tagline -->
    <div class="overlay-item" style="--i: 2">
      <p class="overlay-tagline">{tagline}</p>
    </div>

    <!-- Description -->
    {
      description && (
        <div class="overlay-item" style="--i: 3">
          <p class="overlay-description">{description}</p>
        </div>
      )
    }

    <!-- Features -->
    {
      features.map((feat, i) => (
        <div class="overlay-item" style={`--i: ${i + (description ? 4 : 3)}`}>
          <div class="overlay-feature">
            <span class="overlay-feature-num">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span>{feat}</span>
          </div>
        </div>
      ))
    }

    <!-- CTA Button -->
    <div
      class="overlay-item"
      style={`--i: ${features.length + (description ? 4 : 3)}`}
    >
      <a href={ctaLink} class="overlay-cta">
        <span>{cta}</span>
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  /* ───────── BACKDROP & WRAPPER ───────── */
  .modality-overlay {
    opacity: 0;
    pointer-events: none; /* Let clicks/scrolls pass through backdrop */
    transition: opacity 500ms cubic-bezier(0.25, 1, 0.5, 1);
    background: rgba(245, 245, 250, 0.25);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    /* Hardware acceleration to ensure smooth, synchronous rendering without lag */
    will-change: opacity, backdrop-filter;
    transform: translateZ(0);
  }

  .modality-overlay.active {
    opacity: 1;
    /* Wrapper stays transparent to interactions */
    pointer-events: none;
  }

  /* But active elements INSIDE the overlay MUST catch clicks */
  .modality-overlay.active .overlay-body,
  .modality-overlay.active .overlay-close {
    pointer-events: auto;
  }

  /* ───────── CLOSE ───────── */
  .overlay-close {
    background: none;
    border: none;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    width: 44px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity 300ms cubic-bezier(0.25, 1, 0.5, 1) 400ms,
      transform 300ms cubic-bezier(0.25, 1, 0.5, 1) 400ms;
  }

  .modality-overlay.active .overlay-close {
    opacity: 1;
    transform: scale(1);
  }

  .overlay-close:hover svg {
    stroke: #28286f;
    transform: rotate(90deg);
    transition: all 0.3s ease;
  }

  @media (min-width: 768px) {
    .overlay-close {
      width: 56px;
      height: 46px;
    }
  }

  /* ───────── BODY ───────── */
  .overlay-body {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 5rem 2rem 3rem;
    max-width: 600px;
  }

  @media (min-width: 640px) {
    .overlay-body {
      padding: 5rem 3rem 3rem;
    }
  }

  @media (min-width: 768px) {
    .overlay-body {
      padding: 4rem 5rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-body {
      padding: 4rem 0 4rem 10rem;
      max-width: 720px;
    }
  }

  @media (min-width: 1536px) {
    .overlay-body {
      padding-left: 14rem;
    }
  }

  /* ───────── STAGGERED ITEMS ───────── */
  .overlay-item {
    transform: translateX(-20px);
    opacity: 0;
    transition:
      transform 400ms cubic-bezier(0.25, 1, 0.5, 1),
      opacity 400ms cubic-bezier(0.25, 1, 0.5, 1);
    transition-delay: calc(var(--i) * 70ms + 100ms);
  }

  .modality-overlay.active .overlay-item {
    transform: translateX(0);
    opacity: 1;
  }

  /* ───────── TAG ───────── */
  .overlay-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: rgba(66, 66, 165, 0.5);
    margin-bottom: 0.75rem;
  }

  @media (min-width: 1024px) {
    .overlay-tag {
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }
  }

  /* ───────── TITLE ───────── */
  .overlay-title {
    font-size: 3rem;
    font-weight: 700;
    color: #28286f;
    line-height: 1;
    margin: 0 0 0.35rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .overlay-title {
      font-size: 4.5rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-title {
      font-size: 5.5rem;
    }
  }

  /* ───────── TAGLINE ───────── */
  .overlay-tagline {
    font-size: 1.1rem;
    color: rgba(42, 34, 134, 0.55);
    font-weight: 400;
    margin: 0 0 2rem;
    letter-spacing: 0.01em;
  }

  @media (min-width: 768px) {
    .overlay-tagline {
      font-size: 1.35rem;
      margin-bottom: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-tagline {
      font-size: 1.5rem;
      margin-bottom: 3rem;
    }
  }

  /* ───────── DESCRIPTION ───────── */
  .overlay-description {
    font-size: 0.95rem;
    color: rgba(42, 34, 134, 0.5);
    font-weight: 400;
    line-height: 1.6;
    margin: -0.5rem 0 2rem;
    max-width: 500px;
  }

  @media (min-width: 768px) {
    .overlay-description {
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-description {
      font-size: 1.1rem;
      margin-bottom: 3rem;
    }
  }

  /* ───────── FEATURE ROW ───────── */
  .overlay-feature {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    font-size: 1rem;
    color: rgba(42, 34, 134, 0.8);
    line-height: 1.4;
    border-bottom: 1px solid rgba(66, 66, 165, 0.06);
  }

  @media (min-width: 768px) {
    .overlay-feature {
      font-size: 1.15rem;
      padding: 0.75rem 0;
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-feature {
      font-size: 1.25rem;
      padding: 0.85rem 0;
    }
  }

  .overlay-feature-num {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(66, 66, 165, 0.3);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 768px) {
    .overlay-feature-num {
      font-size: 0.85rem;
    }
  }

  /* ───────── CTA ───────── */
  .overlay-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    font-size: 1rem;
    font-weight: 600;
    color: #4242a5;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @media (min-width: 768px) {
    .overlay-cta {
      font-size: 1.15rem;
      margin-top: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .overlay-cta {
      font-size: 1.25rem;
      margin-top: 3rem;
    }
  }

  .overlay-cta svg {
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .overlay-cta:hover {
    color: #28286f;
  }

  .overlay-cta:hover svg {
    transform: translateX(6px);
  }

  /* ───────── EXIT ───────── */
  .modality-overlay.closing .overlay-item {
    transform: translateX(-10px);
    opacity: 0;
    transition-delay: 0ms;
    transition-duration: 200ms;
  }

  .modality-overlay.closing .overlay-close {
    opacity: 0;
    transform: scale(0.8);
    transition-delay: 0ms;
    transition-duration: 200ms;
  }
</style>
