---
import { Icon } from "astro-icon/components";

interface Props {
  className?: string;
  text: string;
  link: string;
  target?: string;
  title?: string;
  style?: string; // recebe a cor de fundo dinâmica do WordPress
}

const {
  className = "",
  text,
  link,
  target = "_self",
  title = "Saiba mais",
  style,
} = Astro.props;

const relAttribute = target === "_blank" ? "noopener norefferer" : undefined;
---

<div
  class:list={[
    "announcement-bar w-full py-2 z-1 md:p-4 flex relative items-center justify-center min-h-[40px] px-8 md:px-16 text-black",
    className,
  ]}
  style={style}
  role="region"
  aria-label="Aviso importante"
>
  <!-- Mobile: Entire bar is the link, overlaid on top -->
  <a
    href={link}
    target={target}
    rel={relAttribute}
    title={title}
    class="md:hidden absolute inset-0 z-10 w-full h-full block"
    aria-label={title}
  >
  </a>

  <p
    class="font-bold text-[clamp(0.6rem,2vw,1.125rem)] text-center whitespace-nowrap overflow-hidden text-ellipsis md:mr-0 mr-2"
  >
    {text}
  </p>

  <!-- Desktop: Only the icon is the link -->
  <a
    href={link}
    target={target}
    rel={relAttribute}
    title={title}
    class="hidden md:block absolute right-4 md:right-8 hover:opacity-80 transition-opacity"
    aria-label={title}
  >
    <Icon name="akar-icons:link-out" class="w-6 h-6 md:w-5 md:h-5" />
  </a>
</div>
