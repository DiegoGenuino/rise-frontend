---
import { Image } from "astro:assets";

import ExecIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-exec.svg";
import AcadIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-acad.svg";
import JuridicoIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-juridico.svg";
import PrepIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-prep.svg";
import TeensIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-teens.svg";
import KidsIcon from "../../assets/icons/modality-navbar-kit/navbar-icon-kids.svg";
---

<style>
  /* Base Glass Container Wrapper */
  .navbar-glass {
    position: relative;
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    z-index: 20;
    transition: padding 0.3s ease;

    /* Real glass distortion */
    backdrop-filter: blur(0.3px) saturate(160%);
    -webkit-backdrop-filter: blur(0.5px) saturate(160%);

    /* Faint white border with low opacity */
    border: 1px solid rgba(255, 255, 255, 0.35);

    /* Inner highlight at top, inner shading at bottom + Soft outer shadow floating depth */
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.4),
      inset 0 -2px 6px rgba(0, 0, 0, 0.05),
      0 12px 32px rgba(30, 30, 80, 0.15);
  }

  /* Simulate volumetric liquid highlight */
  .navbar-glass::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(255, 255, 255, 0.45) 0%,
      rgba(255, 255, 255, 0) 50%
    );
    pointer-events: none;
    z-index: -1;
  }

  /* Tab Buttons */
  .tab-button {
    position: relative;
    z-index: 10;
    border-radius: 9999px;
    border: none;
    background: transparent;
    font-weight: 400;
    -webkit-text-stroke: 0px transparent;
    color: rgba(30, 30, 80, 0.65);
    white-space: nowrap;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: all 0.3s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tab-button.active {
    color: #28286f;
    -webkit-text-stroke: 0.2px #28286f;
  }

  .tab-button:hover:not(.active) {
    color: #28286f;
  }

  .tab-button:focus-visible {
    outline: 2px solid rgba(100, 100, 255, 0.5);
    outline-offset: 2px;
  }

  /* Responsive Sizing */
  .navbar-glass {
    padding: 0.25rem;
  }
  .tab-button {
    /* Responsive mobile squares to prevent horizontal overflow on <450px screens */
    width: 3.75rem;
    height: 3.75rem;
    padding: 0;
    margin: 0 0.05rem;
    border-radius: 9999px;
  }

  .mobile-icon {
    width: 3.75rem;
    height: 3.75rem;
    filter: grayscale(100%) blur(0.8px);
    transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .tab-button.active .mobile-icon {
    filter: grayscale(0%);
  }

  /* 'sm' breakpoint (~768px) */
  @media (max-width: 768px) {
    .navbar-glass {
      padding: 0.6rem;
    }
    .tab-button {
      width: 3.25rem;
      height: 3.25rem;
      margin: 0 0.125rem;
    }

    .mobile-icon {
      width: 3rem;
      height: 3rem;
    }
  }

  @media (min-width: 768px) {
    .navbar-glass {
      padding: 0.6rem;
    }
    .tab-button,
    .tab-button.active {
      width: auto;
      height: auto;
      padding: 0.65rem 1.25rem;
      font-size: 0.95rem;
      margin: 0 0.2rem;
    }
  }

  @media (min-width: 1024px) {
    .navbar-glass {
      padding: 0.5rem;
    }
    .tab-button,
    .tab-button.active {
      width: auto;
      height: auto;
      padding: 0.75rem 1.75rem;
      font-size: 1.1rem;
      margin: 0 0.25rem;
    }
  }

  @media (min-width: 1536px) {
    .navbar-glass {
      padding: 0.625rem;
    }
    .tab-button,
    .tab-button.active {
      width: auto;
      height: auto;
      padding: 0.875rem 2.25rem;
      font-size: 1.25rem;
      margin: 0 0.375rem;
    }
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<nav
  class="flex justify-center mb-4 lg:mb-6 shrink-0 w-full py-4 px-4 sm:px-12"
  role="tablist"
  aria-label="Modalidades de ensino"
>
  <div class="navbar-glass" data-tab-container>
    <button
      class="tab-button active"
      role="tab"
      aria-selected="true"
      aria-controls="executivo-panel"
      id="executivo-tab"
      data-tab="executivo"
    >
      <span class="hidden md:block">executivo</span>
      <Image
        src={ExecIcon}
        alt="Executivo"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
    <button
      class="tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="academico-panel"
      id="academico-tab"
      data-tab="academico"
    >
      <span class="hidden md:block">acadêmico</span>
      <Image
        src={AcadIcon}
        alt="Acadêmico"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
    <button
      class="tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="juridico-panel"
      id="juridico-tab"
      data-tab="juridico"
    >
      <span class="hidden md:block">jurídico</span>
      <Image
        src={JuridicoIcon}
        alt="Jurídico"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
    <button
      class="tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="preparatorio-panel"
      id="preparatorio-tab"
      data-tab="preparatorio"
    >
      <span class="hidden md:block">preparatório</span>
      <Image
        src={PrepIcon}
        alt="Preparatório"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
    <button
      class="tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="teens-panel"
      id="teens-tab"
      data-tab="teens"
    >
      <span class="hidden md:block">teens</span>
      <Image
        src={TeensIcon}
        alt="Teens"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
    <button
      class="tab-button"
      role="tab"
      aria-selected="false"
      aria-controls="kids-panel"
      id="kids-tab"
      data-tab="kids"
    >
      <span class="hidden md:block">kids</span>
      <Image
        src={KidsIcon}
        alt="Kids"
        class="mobile-icon md:hidden object-cover rounded-full"
      />
    </button>
  </div>
</nav>
