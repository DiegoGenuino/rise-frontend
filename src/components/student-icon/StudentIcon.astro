---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className = '' } = Astro.props;
---

<div class={`student-card relative overflow-hidden shrink-0 ${className}`}>
  <img
    src={src}
    alt={alt}
    class="w-full h-full object-cover object-top"
    loading="lazy"
  />
  <!-- liquid glass overlay -->
  <div class="glass-overlay absolute inset-0 pointer-events-none"></div>
</div>

<style>
  .student-card {
    border-radius: 1.35rem;
    box-shadow:
      0 8px 32px rgba(80, 80, 180, 0.18),
      0 2px 8px rgba(0, 0, 0, 0.10);
  }

  .glass-overlay {
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.38) 0%,
      rgba(255, 255, 255, 0.08) 35%,
      rgba(255, 255, 255, 0.00) 60%,
      rgba(180, 170, 255, 0.10) 100%
    );
    box-shadow:
      inset 0 1.5px 2px rgba(255, 255, 255, 0.85),
      inset 0 -1px 1px rgba(100, 80, 200, 0.15);
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(0.5px);
    -webkit-backdrop-filter: blur(0.5px);
  }
</style>