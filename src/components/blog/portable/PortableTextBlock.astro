---
import type {SanityPortableTextBlock, SanityPortableTextMarkDef} from "../../../lib/sanity.types";

interface Props {
  block: SanityPortableTextBlock;
  compact?: boolean;
}

const {block, compact = false} = Astro.props;

function escapeHtml(value: string): string {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function slugifyValue(value: string): string {
  return value
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "")
    .slice(0, 96);
}

function sanitizeHref(href?: string): string | null {
  if (!href) {
    return null;
  }

  if (href.startsWith("/") || href.startsWith("#")) {
    return href;
  }

  try {
    const parsed = new URL(href);
    if (["http:", "https:", "mailto:", "tel:"].includes(parsed.protocol)) {
      return href;
    }
  } catch {
    return null;
  }

  return null;
}

function applyDecorator(mark: string, html: string): string {
  switch (mark) {
    case "strong":
      return `<strong>${html}</strong>`;
    case "em":
      return `<em>${html}</em>`;
    case "underline":
      return `<span class=\"portable-underline\">${html}</span>`;
    case "strike-through":
      return `<span class=\"portable-strike\">${html}</span>`;
    case "code":
      return `<code class=\"portable-inline-code\">${html}</code>`;
    case "highlight":
      return `<mark class=\"portable-highlight\">${html}</mark>`;
    default:
      return html;
  }
}

function applyMarkDef(markDef: SanityPortableTextMarkDef, html: string): string {
  if (markDef._type === "link") {
    const safeHref = sanitizeHref(markDef.href);
    if (!safeHref) {
      return html;
    }

    const openInNewTab = Boolean(markDef.openInNewTab);
    const attrs = openInNewTab ? " target=\"_blank\" rel=\"noopener noreferrer\"" : "";
    return `<a href=\"${escapeHtml(safeHref)}\"${attrs}>${html}</a>`;
  }

  if (markDef._type === "internalLink") {
    if (!markDef.slug) {
      return html;
    }

    return `<a href=\"/blog/${escapeHtml(markDef.slug)}\">${html}</a>`;
  }

  return html;
}

function renderSpans(portableBlock: SanityPortableTextBlock): string {
  const markDefs = new Map<string, SanityPortableTextMarkDef>();
  for (const markDef of portableBlock.markDefs || []) {
    markDefs.set(markDef._key, markDef);
  }

  return (portableBlock.children || [])
    .map((span) => {
      let html = escapeHtml(span.text || "");

      for (const mark of span.marks || []) {
        const markDef = markDefs.get(mark);
        if (markDef) {
          html = applyMarkDef(markDef, html);
        } else {
          html = applyDecorator(mark, html);
        }
      }

      return html;
    })
    .join("");
}

function resolveHeadingId(portableBlock: SanityPortableTextBlock, contentHtml: string): string {
  const normalizedKey = portableBlock._key ? slugifyValue(portableBlock._key) : "";
  if (normalizedKey) {
    return `pt-h-${normalizedKey}`;
  }

  const normalizedText = slugifyValue(contentHtml.replace(/<[^>]+>/g, ""));
  return normalizedText || "pt-heading";
}

function buildBlockHtml(portableBlock: SanityPortableTextBlock): string {
  const contentHtml = renderSpans(portableBlock);
  const compactClass = compact ? " portable-compact" : "";

  if (portableBlock.listItem === "number") {
    return `<ol class=\"portable-list-number${compactClass}\"><li>${contentHtml}</li></ol>`;
  }

  if (portableBlock.listItem === "bullet") {
    return `<ul class=\"portable-list-bullet${compactClass}\"><li>${contentHtml}</li></ul>`;
  }

  const style = portableBlock.style || "normal";
  if (style === "h2" || style === "h3" || style === "h4") {
    const headingId = resolveHeadingId(portableBlock, contentHtml);
    return `<${style} id=\"${headingId}\" class=\"portable-heading portable-${style}${compactClass}\">${contentHtml}</${style}>`;
  }

  if (style === "blockquote") {
    return `<blockquote class=\"portable-blockquote${compactClass}\">${contentHtml}</blockquote>`;
  }

  return `<p class=\"portable-paragraph${compactClass}\">${contentHtml}</p>`;
}

const renderedHtml = buildBlockHtml(block);
---

<Fragment set:html={renderedHtml} />

<style>
  :global(.portable-paragraph) {
    margin-bottom: 20px;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.82;
    color: rgba(17, 17, 32, 0.75);
  }

  :global(.portable-heading) {
    color: #111120;
  }

  :global(.portable-h2) {
    margin: 56px 0 24px;
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 400;
    letter-spacing: 0.03em;
    line-height: 0.92;
  }

  :global(.portable-h3) {
    margin: 36px 0 14px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  :global(.portable-h4) {
    margin: 28px 0 12px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #2b2ba8;
  }

  :global(.portable-blockquote) {
    margin: 36px 0;
    padding-left: 22px;
    border-left: 2px solid rgba(17, 17, 32, 0.28);
    font-size: 19px;
    line-height: 1.58;
    color: #111120;
  }

  :global(.portable-list-bullet),
  :global(.portable-list-number) {
    margin: 0 0 12px;
    padding-left: 22px;
    color: rgba(17, 17, 32, 0.82);
    font-size: 16px;
    line-height: 1.72;
  }

  :global(.portable-list-bullet li),
  :global(.portable-list-number li) {
    margin: 6px 0;
  }

  :global(.portable-inline-code) {
    border: 1px solid rgba(17, 17, 32, 0.14);
    background: rgba(17, 17, 32, 0.05);
    padding: 1px 6px;
    font-family: "Geist Mono", monospace;
    font-size: 0.92em;
    border-radius: 3px;
    color: #111120;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(.portable-highlight) {
    background: rgba(255, 229, 0, 0.4);
    color: inherit;
  }

  :global(.portable-underline) {
    text-decoration: underline;
  }

  :global(.portable-strike) {
    text-decoration: line-through;
  }

  :global(.portable-paragraph a),
  :global(.portable-blockquote a),
  :global(.portable-list-bullet a),
  :global(.portable-list-number a),
  :global(.portable-heading a) {
    color: #2b2ba8;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  :global(.portable-compact) {
    margin-top: 0;
    margin-bottom: 12px;
  }

  @media (max-width: 900px) {
    :global(.portable-paragraph) {
      margin-bottom: 18px;
      font-size: 15.5px;
      line-height: 1.76;
    }

    :global(.portable-h2) {
      margin: 48px 0 22px;
      font-size: clamp(32px, 6.8vw, 46px);
    }

    :global(.portable-h3) {
      margin: 30px 0 12px;
      font-size: 14px;
      letter-spacing: 0.14em;
    }

    :global(.portable-h4) {
      margin: 24px 0 10px;
      font-size: 12px;
      letter-spacing: 0.12em;
    }

    :global(.portable-blockquote) {
      margin: 30px 0;
      padding-left: 18px;
      font-size: 17px;
      line-height: 1.6;
    }

    :global(.portable-list-bullet),
    :global(.portable-list-number) {
      margin: 0 0 10px;
      padding-left: 20px;
      font-size: 15px;
      line-height: 1.68;
    }

    :global(.portable-list-bullet li),
    :global(.portable-list-number li) {
      margin: 5px 0;
    }

    :global(.portable-compact) {
      margin-bottom: 10px;
    }
  }

  @media (max-width: 600px) {
    :global(.portable-paragraph) {
      margin-bottom: 16px;
      font-size: 15px;
      line-height: 1.72;
    }

    :global(.portable-h2) {
      margin: 40px 0 18px;
      font-size: clamp(28px, 10.5vw, 38px);
      line-height: 0.96;
    }

    :global(.portable-h3) {
      margin: 24px 0 10px;
      font-size: 13px;
      letter-spacing: 0.12em;
    }

    :global(.portable-h4) {
      margin: 20px 0 8px;
      font-size: 11.5px;
      letter-spacing: 0.1em;
    }

    :global(.portable-blockquote) {
      margin: 24px 0;
      padding-left: 14px;
      font-size: 16px;
      line-height: 1.58;
    }

    :global(.portable-list-bullet),
    :global(.portable-list-number) {
      margin: 0 0 8px;
      padding-left: 18px;
      font-size: 14.5px;
      line-height: 1.64;
    }

    :global(.portable-list-bullet li),
    :global(.portable-list-number li) {
      margin: 4px 0;
    }

    :global(.portable-compact) {
      margin-bottom: 8px;
    }
  }
</style>
