---
interface Props {
  title?: string,
  description?: string  
}

const { title = "Rise Idiomas", description = "Aprenda inglês de forma estratégica." } = Astro.props;
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
