---
import riseTypeGradient from "../../assets/icons/rise-type-gradient.svg";

const subheaderText =
  "Cursos imersivos e personalizados para crianças, adolescentes e profissionais.";
---

<!-- HERO SECTION -->
<section
  class="hero-section background relative flex flex-col
    w-full min-h-svh
    px-2 py-6
    sm:p-12
    md:p-16
    lg:h-auto lg:min-h-[160vh] lg:p-12
    xl:p-16
    2xl:px-32 2xl:pt-16 2xl:pb-16"
  id="hero"
>
  <!-- Title + desktop subheader -->
  <header
    class="hero-header hero-animate hero-animate-delay-1 relative z-10 w-full shrink-0
      h-[12em]
      sm:h-auto
      md:h-auto
      lg:h-[22rem]
      2xl:h-[24rem]"
  >
    <!-- fix responsivity for mobile [line 222]: large words overflow vw -->
    <h1
      class="hero-title font-display w-full bg-gradient-to-r from-[#401EFF] via-[#9090FF] to-[#C0C0FF]
        bg-clip-text text-transparent leading-[1.1] pb-3 overflow-visible select-none
        text-8xl
        sm:text-8xl
        md:text-7xl
        lg:text-9xl
        2xl:text-[8rem]"
      id="hero-header"
    >
    </h1>

    <p
      class="hero-animate hero-animate-delay-2 hidden text-[#4242A5E5]
        sm:block sm:text-lg sm:mt-2
        md:text-xl md:mt-3
        lg:absolute lg:inset-x-0 lg:mt-0 lg:text-2xl lg:top-[19rem]
        2xl:top-[20rem]"
      id="hero-subheader-desktop"
    >
      {subheaderText}
    </p>
  </header>

  <!-- Spacer: pushes content toward bottom on mobile/tablet -->
  <div class="hero-spacer flex-1 min-h-12 sm:min-h-16 lg:hidden"></div>

  <!-- RISE logo (CRT energize reveal on scroll) -->
  <div
    class="hero-svg-container shrink-0 flex justify-center overflow-hidden items-start
      h-[24vh]
      sm:h-[26vh]
      lg:flex-1 lg:h-auto lg:overflow-visible lg:items-end lg:mt-12
      2xl:mt-16"
    id="hero-svg-wrapper"
  >
    <img
      src={riseTypeGradient.src}
      alt="RISE"
      class="h-auto
        w-[90%]
        sm:w-[80%]
        md:w-[70%]
        lg:w-[60%]
        2xl:w-[75%]"
      width="936"
      height="512"
    />
  </div>
</section>

<script>
  import Typewriter from "typewriter-effect/dist/core";

  // Typewriter configuration
  const PAUSE_BETWEEN = 300; // transition gap between phrases
  const PAUSE_READ = 3500; // standard reading time
  const PAUSE_READ_LONG = 4500; // emphasized reading time

  const heroHeader = document.getElementById("hero-header");

  const isMobile = window.matchMedia("(max-width: 639px)").matches;
  const MAX_MOBILE_LENGTH = 12; //mobile max lenght is 12 chars to avoid overflow

  const phrases: { text: string; pauseFor: number }[] = [
    // Portuguese
    { text: "sua carreira", pauseFor: PAUSE_READ_LONG },
    { text: "seu futuro", pauseFor: PAUSE_READ },
    { text: "suas conquistas", pauseFor: PAUSE_READ },
    { text: "suas viagens", pauseFor: PAUSE_READ },
    { text: "seu intercâmbio", pauseFor: PAUSE_READ },
    // English
    { text: "your career", pauseFor: PAUSE_READ },
    { text: "your future", pauseFor: PAUSE_READ },
    { text: "your success", pauseFor: PAUSE_READ_LONG },
    // Spanish
    { text: "tu carrera", pauseFor: PAUSE_READ },
    { text: "tu futuro", pauseFor: PAUSE_READ },
    { text: "tus logros", pauseFor: PAUSE_READ },
  ];

  // if is mobile filters only phrases with less than 12 chars
  const filtered = isMobile
    ? phrases.filter((p) => p.text.length <= MAX_MOBILE_LENGTH)
    : phrases;

  const typewriter = new Typewriter(heroHeader, {
    loop: true,
    delay: 50, // typing speed (ms per char)
    deleteSpeed: 25, // deletion speed (ms per char)
    cursor: "|",
    cursorClassName: "typewriter-cursor",
  });

  typewriter.typeString("Idiomas para ");

  filtered.forEach((phrase) => {
    typewriter
      .typeString(phrase.text)
      .pauseFor(phrase.pauseFor)
      .deleteChars(phrase.text.length)
      .pauseFor(PAUSE_BETWEEN);
  });

  typewriter.start();

  // Parallax fade on RISE logo
  const svgWrapper = document.getElementById("hero-svg-wrapper");

  if (svgWrapper) {
    svgWrapper.style.transition =
      "opacity 0.15s ease-out, transform 0.15s ease-out";

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const vh = window.innerHeight;
          const fadeStart = vh * 0.3;
          const fadeEnd = vh * 0.9;

          if (scrollY <= fadeStart) {
            svgWrapper.style.opacity = "1";
            svgWrapper.style.transform = "translateY(0)";
          } else if (scrollY >= fadeEnd) {
            svgWrapper.style.opacity = "0.15";
            svgWrapper.style.transform = "translateY(20px)";
          } else {
            const progress = (scrollY - fadeStart) / (fadeEnd - fadeStart);
            svgWrapper.style.opacity = String(1 - progress * 0.85);
            svgWrapper.style.transform = `translateY(${progress * 20}px)`;
          }

          ticking = false;
        });
        ticking = true;
      }
    });

    // ── CRT energize: reveal RISE logo on first scroll ──
    let energized = false;
    const triggerEnergize = () => {
      if (!energized && window.scrollY > 50) {
        energized = true;
        svgWrapper.classList.add("crt-energized");
        window.removeEventListener("scroll", triggerEnergize);
      }
    };

    // Delay listener until entrance animations complete
    setTimeout(() => {
      window.addEventListener("scroll", triggerEnergize, { passive: true });
    }, 1500);
  }
</script>

<style is:global>
  /* Typewriter cursor */

  .typewriter-cursor {
    font-weight: 900;
    font-size: inherit;
    background: linear-gradient(to right, #6262ff, #9090ff, #c0c0ff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* CRT glow & flicker on title text */

  .hero-title {
    filter: drop-shadow(0 0 8px rgba(100, 100, 255, 0.3))
      drop-shadow(0 0 20px rgba(64, 30, 255, 0.15));
    animation: crtFlicker 4s ease-in-out infinite;
  }

  @keyframes crtFlicker {
    0%,
    92%,
    94%,
    97%,
    100% {
      opacity: 1;
    }
    93% {
      opacity: 0.95;
    }
    96% {
      opacity: 0.97;
    }
  }

  /* ──────────────────────────────────────────
     CRT energize reveal on RISE logo
     Starts invisible, fades in with glow on scroll
     ────────────────────────────────────────── */

  .hero-svg-container img {
    opacity: 0;
  }

  .hero-svg-container.crt-energized img {
    animation: crtEnergize 3s ease-in-out forwards;
  }

  @keyframes crtEnergize {
    0% {
      opacity: 0;
      filter: brightness(1) drop-shadow(0 0 0px transparent);
    }
    15% {
      opacity: 0.4;
      filter: brightness(2) drop-shadow(0 0 20px rgba(64, 30, 255, 0.6));
    }
    30% {
      opacity: 0.7;
      filter: brightness(1.4) drop-shadow(0 0 12px rgba(100, 100, 255, 0.4));
    }
    45% {
      opacity: 0.85;
      filter: brightness(1.8) drop-shadow(0 0 18px rgba(64, 30, 255, 0.5));
    }
    60% {
      opacity: 0.95;
      filter: brightness(1.3) drop-shadow(0 0 10px rgba(100, 100, 255, 0.3));
    }
    75% {
      opacity: 1;
      filter: brightness(1.15) drop-shadow(0 0 6px rgba(100, 100, 255, 0.15));
    }
    100% {
      opacity: 1;
      filter: brightness(1) drop-shadow(0 0 0px transparent);
    }
  }

  /* Staggered entrance animation */

  @keyframes heroFadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-animate {
    opacity: 0;
    animation: heroFadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-animate-delay-1 {
    animation-delay: 0.15s;
  }
  .hero-animate-delay-2 {
    animation-delay: 0.4s;
  }
  .hero-animate-delay-3 {
    animation-delay: 0.65s;
  }
  .hero-animate-delay-4 {
    animation-delay: 0.9s;
  }

  /* Accessibility: respect reduced motion */

  @media (prefers-reduced-motion: reduce) {
    .hero-animate {
      opacity: 1;
      animation: none;
    }
  }

  /* ──────────────────────────────────────────
     Landscape mobile (short viewport) overrides
     Mirrors desktop layout at proportional scale
     ────────────────────────────────────────── */

  @media (max-height: 600px) and (orientation: landscape) {
    .hero-section {
      min-height: 160svh !important;
      height: auto !important;
      padding: 2rem 3rem !important;
    }

    .hero-header {
      height: auto !important;
      min-height: auto !important;
      margin-bottom: 0 !important;
      flex-shrink: 0 !important;
      overflow: visible !important;
    }

    .hero-title {
      font-size: 4.5rem !important;
      line-height: 1.2 !important;
      text-align: center !important;
    }

    .hero-header h2 {
      display: block !important;
      position: relative !important;
      top: auto !important;
      font-size: 0.9rem !important;
      margin-top: 0.5rem !important;
      text-align: center !important;
    }

    .hero-spacer,
    .hero-mobile-subheader {
      display: none !important;
    }

    .hero-svg-container {
      flex: 1 1 auto !important;
      height: auto !important;
      min-height: 40svh !important;
      overflow: visible !important;
      display: flex !important;
      align-items: flex-end !important;
      justify-content: center !important;
      margin-top: 1rem !important;
    }

    .hero-svg-container img {
      width: 55% !important;
    }
  }
</style>