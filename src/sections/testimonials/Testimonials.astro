---
import TestimonialCard from "../../components/testimonial-card/TestimonialCard.astro";
import TestimonialsTypeBg from "../../components/testimonial-type-bg/TestimonialsTypeBg.astro";
import testimonialsData from "../../data/Testimonials.json";
---

 
<div id="testimonials" class="overflow-hidden h-fit py-20 lg:pb-55 lg:pt-50">
    <TestimonialsTypeBg aria-hidden="true" />
    <div class="testimonials-carousel">
        <div class="testimonials-track">
            {
                testimonialsData.testimonials.map((data) => (
                    <TestimonialCard
                        studentName={data.studentName}
                        testimonial={data.testimonial}
                        courseModality={data.courseModality}
                    />
                ))
            }
        </div>
        <div aria-hidden="true" class="testimonials-track">
            {
                testimonialsData.testimonials.map((data) => (
                    <TestimonialCard
                        studentName={data.studentName}
                        testimonial={data.testimonial}
                        courseModality={data.courseModality}
                    />
                ))
            }
        </div>
        
        
    </div>

    <!-- Decorative second track explicitly for larger devices -->
    <div aria-hidden="true" class="testimonials-carousel testimonials-carousel--reverse">
        <div class="testimonials-track testimonials-track--reverse">
            {
                testimonialsData.testimonials.map((data) => (
                    <TestimonialCard
                        studentName={data.studentName}
                        testimonial={data.testimonial}
                        courseModality={data.courseModality}
                    />
                ))
            }
        </div>
        <div class="testimonials-track testimonials-track--reverse">
            {
                testimonialsData.testimonials.map((data) => (
                    <TestimonialCard
                        studentName={data.studentName}
                        testimonial={data.testimonial}
                        courseModality={data.courseModality}
                    />
                ))
            }
        </div>
    </div>
</div>

<style> 
    .testimonial-cards-container {
        position: absolute;
        top: -1%;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center; 
        z-index: 10;
        pointer-events: none;
    }

    .testimonials-track {
        width: 100%;
        will-change: transform;
        animation: testimonials-scroll 40s linear infinite;
        display: flex;
        gap: 4rem;
        /* Add padding to the right to create a gap between the last and first card. */
        padding-right: 4rem;
        margin: 3rem auto;
    }

    .testimonials-track--reverse {
        animation-direction: reverse;
        animation-duration: 60s;
    }

    .testimonials-carousel {
        position: absolute;
        z-index: 10;
        display: flex;
        margin: 0 auto;
        padding: 4rem auto;
        overflow: hidden;
        width: fit-content%;
        height: fit-content;
        transform: translateY(-180%);
    }

    .testimonials-carousel--reverse {
        transform: translateY(-90%);
        z-index: 1;
        filter: blur(7px);
    }

    @keyframes testimonials-scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-100%);
        }
    }

    @media (max-width: 524px) {
        .testimonials-carousel {
            transform: translateY(-150%);
        }
        .testimonials-carousel--reverse {
            display: none;
        }
    }
</style>