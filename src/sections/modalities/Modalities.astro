---
import "@fontsource/schoolbell";
import "@fontsource/playfair-display";
import "@fontsource/unifrakturcook";
import "@fontsource/geist-mono";

import ModalityNavbar from "../../components/modality-navbar/ModalityNavbar.astro";
import ModalityPanel from "../../components/modality-panel/ModalityPanel.astro";

//  Executivo panel assets
import execKeyboard from "../../assets/images/modalities-section/exec-panel-element.png";

//  Acadêmico panel assets
import acadStudent from "../../assets/images/modalities-section/acad-panel-student-element.png";
import acadGlobeCollage from "../../assets/images/modalities-section/acad-panel-globe-collage-element.png";

//  Jurídico panel assets
import juridicoElement from "../../assets/images/modalities-section/juridico-panel-element.png";

// Preparatório panel assets
import prepStudent from "../../assets/images/modalities-section/prep-panel-boy-element.png";
import prepCambridgeBadge from "../../assets/images/modalities-section/prep-panel-cambridge-element.png";
import prepMichiganBadge from "../../assets/images/modalities-section/prep-panel-michigan-element.png";

//  Teens panel assets
import teensGirlOpen from "../../assets/images/modalities-section/teens-panel-girl-element-f1.png";
import teensGirlBlink from "../../assets/images/modalities-section/teens-panel-girl-element-f2.png";
import teensBook from "../../assets/images/modalities-section/teens-panel-book-element.png";
import teensCamera from "../../assets/images/modalities-section/teens-panel-camera-element.png";
import teensMegaphone from "../../assets/images/modalities-section/teens-panel-megaphone-element.png";
//  Kids panel assets
import kidsFrame1 from "../../assets/images/modalities-section/kids-panel-kid-element-f1.png";
import kidsFrame2 from "../../assets/images/modalities-section/kids-panel-kid-element-f2.png";
import kidsFrame3 from "../../assets/images/modalities-section/kids-panel-kid-element-f3.png";
import kidsFrame4 from "../../assets/images/modalities-section/kids-panel-kid-element-f4.png";
import kidsFrame5 from "../../assets/images/modalities-section/kids-panel-kid-element-f5.png";
import kidsSun from "../../assets/images/modalities-section/kids-panel-sun-element.png";
---

<style>
  .tab-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .tab-panel.active {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  /* Prevent image dragging and selection across the entire section */
  :global(#modalidades img) {
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
  }

  /* Custom Title Fonts (global scope to avoid specificity issues) */
  :global(#executivo-panel .title) {
    font-family: "Geist Mono", cursive;
  }
  :global(#juridico-panel .title) {
    font-family: "Playfair Display", cursive;
  }
  :global(#preparatorio-panel .title) {
    font-family: "Playfair Display", cursive;
  }
  :global(#teens-panel .title) {
    font-family: "UnifrakturCook", cursive;
  }
  :global(#kids-panel .title) {
    font-family: "Schoolbell", cursive;
  }
</style>

<section
  id="modalidades"
  class="background relative h-screen flex flex-col z-10"
  aria-labelledby="modalidades-title"
>
  <div
    class="max-w-7xl mx-auto w-full h-full flex flex-col px-8 py-8 sm:px-12 md:px-16 lg:px-20 lg:gap-12"
  >
    <!-- Tab Navigation -->
    <ModalityNavbar />

    <!-- Tab Panels Container -->
    <div class="relative flex-1 w-full">
      <!-- Executivo Panel -->
      <div
        class="tab-panel active"
        role="tabpanel"
        id="executivo-panel"
        aria-labelledby="executivo-tab"
        data-panel="executivo"
      >
        <ModalityPanel
          title="EXECUTIVO"
          subtitle="Confiança & Destaque."
          description="Foco em nuances culturais, diplomacia corporativa e técnicas de persuasão em inglês avançado."
          descriptionClass="text-xl sm:text-2xl text-[#2A2286] leading-relaxed max-w-xl"
          customStyles={`
              .exec-element { cursor: pointer; }
            `}
          images={[
            {
              class:
                "exec-element w-full h-full object-contain drop-shadow-2xl",
              src: execKeyboard,
              alt: "Teclado representando ensino executivo tecnológico",
              data: { "exec-keyboard": "true" },
              widths: [400, 600, 800],
              sizes:
                "(max-width: 640px) 400px, (max-width: 1024px) 600px, 800px",
            },
          ]}
        />
      </div>

      <!-- Acadêmico Panel -->
      <div
        class="tab-panel"
        role="tabpanel"
        id="academico-panel"
        aria-labelledby="academico-tab"
        data-panel="academico"
      >
        <ModalityPanel
          title="ACADÊMICO"
          subtitle="Domínio da Linguagem."
          description="Foco no domínio da linguagem técnica para fins escolares e universitários."
          customStyles={`
            .acad-mask { -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%); mask-image: linear-gradient(to bottom, black 80%, transparent 100%); }
          `}
          images={[
            {
              src: acadStudent,
              alt: "Garoto representando ensino acadêmico",
              class:
                "absolute z-100 -bottom-[5%] lg:-bottom-[10%] right-0 lg:-right-[5%] h-[110%] lg:h-[130%] w-auto object-contain z-10 drop-shadow-2xl acad-mask",
              widths: [400, 600, 800],
              sizes:
                "(max-width: 640px) 400px, (max-width: 1024px) 600px, 800px",
            },
            {
              src: acadGlobeCollage,
              alt: "Colagem com globo representando ensino acadêmico",
              class:
                "absolute -top-[15%] lg:-top-[30%] right-40 lg:right-70 w-[70%] lg:w-[55%] xl:w-[80%] h-auto object-contain z-20 drop-shadow-xl",
              widths: [400, 600, 800],
              sizes:
                "(max-width: 640px) 400px, (max-width: 1024px) 600px, 800px",
            },
          ]}
        />
      </div>

      <!-- Jurídico Panel -->
      <div
        class="tab-panel"
        role="tabpanel"
        id="juridico-panel"
        aria-labelledby="juridico-tab"
        data-panel="juridico"
      >
        <ModalityPanel
          title="JURÍDICO"
          subtitle="Precisão Técnica."
          description="Terminologia jurídica, interpretação de contratos e comunicação profissional para o direito internacional."
          customStyles={`
            .juridico-mask { -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%); mask-image: linear-gradient(to bottom, black 85%, transparent 100%); }
          `}
          images={[
            {
              src: juridicoElement,
              alt: "Ensino jurídico",
              class:
                "w-[120%] h-[120%] -top-[10%] object-contain drop-shadow-2xl relative z-10 juridico-mask origin-bottom",
              loading: "eager",
            },
          ]}
        />
      </div>

      <!-- Preparatório Panel -->
      <div
        class="tab-panel"
        role="tabpanel"
        id="preparatorio-panel"
        aria-labelledby="preparatorio-tab"
        data-panel="preparatorio"
      >
        <ModalityPanel
          title="CURSOS PREPARATÓRIOS"
          subtitle="Visão Internacional."
          description="Sua proficiência comprovada pelas<br class='hidden md:block'/>instituições mais respeitadas do<br class='hidden md:block'/>mundo."
          images={[
            {
              src: prepStudent,
              alt: "Garoto representando preparatório",
              class:
                "absolute -bottom-[5%] lg:-bottom-[10%] right-0 lg:-right-[5%] h-[120%] lg:h-[135%] w-auto object-contain z-10 drop-shadow-2xl",
            },
            {
              src: prepStudent,
              alt: "Garoto Blur",
              class:
                "absolute -bottom-[5%] lg:-bottom-[10%] right-0 lg:-right-[5%] h-[120%] lg:h-[135%] w-auto object-contain z-[15] pointer-events-none",
              style:
                "filter: blur(10px); mask-image: linear-gradient(to bottom, transparent 50%, black 80%); -webkit-mask-image: linear-gradient(to bottom, transparent 50%, black 80%);",
            },
            {
              src: prepCambridgeBadge,
              alt: "Cambridge University",
              class:
                "absolute bottom-[18%] lg:bottom-[22%] right-[25%] lg:right-[32%] w-[55%] lg:w-[65%] h-auto object-contain z-20 hover:-translate-x-2 transition-transform duration-300 drop-shadow-xl",
            },
            {
              src: prepMichiganBadge,
              alt: "Michigan University",
              class:
                "absolute -bottom-[5%] lg:-bottom-[8%] right-[25%] lg:right-[32%] w-[55%] lg:w-[65%] h-auto object-contain z-20 hover:-translate-x-2 transition-transform duration-300 drop-shadow-lg",
            },
          ]}
        />
      </div>

      <!-- Teens Panel -->
      <div
        class="tab-panel"
        role="tabpanel"
        id="teens-panel"
        aria-labelledby="teens-tab"
        data-panel="teens"
      >
        <ModalityPanel
          title="TEENS"
          titleClass="title text-6xl sm:text-7xl lg:text-8xl font-bold text-[#28286F] leading-tight"
          subtitle="Fluência & Cultura."
          description="Inglês dinâmico com foco em cultura pop, tecnologia e preparação para o mundo globalizado."
          customStyles={`
            @keyframes teensBlink { 0%, 95% { opacity: 0; } 95.01%, 98% { opacity: 1; } 98.01%, 100% { opacity: 0; } }
            @keyframes teensBlinkHide { 0%, 95% { opacity: 1; } 95.01%, 98% { opacity: 0; } 98.01%, 100% { opacity: 1; } }
            @keyframes teensFloat1 { 0%, 100% { transform: translateY(0) rotate(-4deg); } 50% { transform: translateY(-12px) rotate(2deg); } }
            @keyframes teensFloat2 { 0%, 100% { transform: translateY(0) rotate(1deg); } 50% { transform: translateY(10px) rotate(-1deg); } }
            @keyframes teensFloat3 { 0%, 100% { transform: translateY(0) rotate(4deg); } 50% { transform: translateY(-8px) rotate(-2deg); } }
            .girl-mask { -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%); mask-image: linear-gradient(to bottom, black 85%, transparent 100%); }
          `}
          images={[
            {
              src: teensGirlOpen,
              alt: "Teens - Garota",
              class:
                "w-full h-full object-contain drop-shadow-2xl relative z-20 scale-[1.25] lg:scale-[1.15] xl:scale-[1.3] origin-bottom girl-mask",
              style: "animation: teensBlinkHide 4.5s infinite running;",
              loading: "eager",
            },
            {
              src: teensGirlBlink,
              alt: "Teens - Garota Piscando",
              class:
                "absolute inset-0 w-full h-full object-contain drop-shadow-2xl z-30 pointer-events-none opacity-0 scale-[1.25] lg:scale-[1.15] xl:scale-[1.3] origin-bottom girl-mask",
              style: "animation: teensBlink 4.5s infinite running;",
              loading: "eager",
            },
            {
              src: teensBook,
              alt: "Livro voando",
              class:
                "absolute top-[5%] -left-[10%] lg:-left-[5%] w-[35%] lg:w-[30%] object-contain z-10 hover:scale-[1.15] transition-transform duration-300 cursor-pointer pointer-events-auto",
              style: "animation: teensFloat1 6s infinite ease-in-out;",
              loading: "eager",
            },
            {
              src: teensCamera,
              alt: "Câmera",
              class:
                "absolute bottom-[-5%] origin-bottom-left -left-[5%] lg:-left-[10%] w-[40%] lg:w-[35%] object-contain z-40 hover:scale-[1.1] hover:-rotate-6 transition-transform duration-300 cursor-pointer pointer-events-auto",
              style: "animation: teensFloat2 5.5s infinite ease-in-out;",
              loading: "eager",
            },
            {
              src: teensMegaphone,
              alt: "Megafone",
              class:
                "absolute bottom-[10%] origin-bottom-right right-0 lg:-right-[15%] w-[45%] lg:w-[45%] object-contain z-40 hover:-translate-y-2 hover:rotate-6 hover:scale-[1.1] transition-transform duration-300 cursor-pointer pointer-events-auto",
              style: "animation: teensFloat3 7s infinite ease-in-out;",
              loading: "eager",
            },
          ]}
        />
      </div>

      <!-- Kids Panel -->
      <div
        class="tab-panel"
        role="tabpanel"
        id="kids-panel"
        aria-labelledby="kids-tab"
        data-panel="kids"
      >
        <!-- kid expression animation is at 'src/scripts' -->
        <ModalityPanel
          title="KIDS"
          titleClass="title text-6xl sm:text-5xl lg:text-8xl font-bold text-[#28286F] leading-tight md:whitespace-nowrap"
          subtitle="Lúdico & Natural."
          description="Metodologia lúdica e interativa para crianças desenvolverem fluência de forma natural e divertida."
          images={[
            {
              src: kidsFrame1,
              alt: "Criança aprendendo inglês",
              class: "hidden w-full h-full object-contain drop-shadow-2xl",
              data: { "kid-frame": true },
              loading: "eager",
            },
            {
              src: kidsFrame2,
              alt: "Criança aprendendo inglês",
              class: "hidden w-full h-full object-contain drop-shadow-2xl",
              data: { "kid-frame": true },
              loading: "eager",
            },
            {
              src: kidsFrame3,
              alt: "Criança aprendendo inglês",
              class: "hidden w-full h-full object-contain drop-shadow-2xl",
              data: { "kid-frame": true },
              loading: "eager",
            },
            {
              src: kidsFrame4,
              alt: "Criança aprendendo inglês",
              class: "hidden w-full h-full object-contain drop-shadow-2xl",
              data: { "kid-frame": true },
              loading: "eager",
            },
            {
              src: kidsFrame5,
              alt: "Criança aprendendo inglês",
              class: "hidden w-full h-full object-contain drop-shadow-2xl",
              data: { "kid-frame": true },
              loading: "eager",
            },
            {
              src: kidsSun,
              alt: "Sol decorativo",
              class:
                "sun-element absolute -top-50 right-0 w-[190px] min-[640px]:-right-20 min-[640px]:-top-60 lg:w-[380px] lg:-left-90 lg:-top-10 -z-10 pointer-events-none opacity-40 max-[500px]:-top-[330px]",
              loading: "eager",
            },
          ]}
          customStyles=""
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { initModalidadesTabs } from "../../scripts/modalidadesTabs";
  import { initKidExpressions } from "../../scripts/kidsAnimations.js";
  import { initExecAnimations } from "../../scripts/execAnimations.js";

  initModalidadesTabs();
  initKidExpressions();
  initExecAnimations();
</script>
