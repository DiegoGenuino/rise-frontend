---

<footer class="blueprint-footer" aria-label="Rodape Rise Idiomas">
  <div class="cell cell-brand">
    <div class="label-mono">Digital System</div>
    <div class="brand-logo-wrap">
      <img src={riseLogo.src} alt="Rise Idiomas" class="brand-logo" loading="lazy" />
    </div>
  </div>

  <div class="cell cell-contact">
    <div class="label-mono">Comunicacao</div>
    <ul class="link-list">
      {
        contatoLinks.map((item) => {
          const isExternal = !item.url.startsWith("/");

          return (
            <li>
              <a
                href={item.url}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
              >
                <span class="arrow">-></span>
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>

  <div class="cell cell-links">
    <div class="label-mono">Informacao</div>
    <ul class="link-list">
      {
        informacaoLinks.map((item) => {
          const isExternal = !item.url.startsWith("/");

          return (
            <li>
              <a
                href={item.url}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
              >
                <span class="arrow">-></span>
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>

  {
    socialLinks.map((item) => (
      <a
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        class="cell cell-social"
        aria-label={item.label}
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={item.path}></path>
        </svg>
        <span>{item.label}</span>
      </a>
    ))
  }

  <div class="cell cell-base">
    <div>{currentYear} RISE IDIOMAS. DESENVOLVIDO POR SUBLIME STUDIO.</div>

    <div class="time-widget">
      <div class="pulsing-dot"></div>
      Sao Paulo, BR - <span id="real-time-clock">00:00:00</span>
    </div>
  </div>

  <div class="cell cell-up">
    <button id="footer-scroll-top" class="up-btn" type="button" title="Voltar ao topo">
      <span aria-hidden="true">↑</span>
    </button>
  </div>
</footer>

<script is:inline>
  const clockEl = document.getElementById("real-time-clock");
  const topBtn = document.getElementById("footer-scroll-top");

  function updateClock() {
    if (!clockEl) return;

    const now = new Date();
    const timeString = now.toLocaleTimeString("pt-BR", {
      timeZone: "America/Sao_Paulo",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });

    clockEl.textContent = timeString;
  }

  updateClock();
  setInterval(updateClock, 1000);

  if (topBtn) {
    topBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>

<style>
  :root {
    --footer-brand-blue: #3e469c;
    --footer-brand-cyan: #4ba6bd;
    --footer-bg-dark: #07080d;
    --footer-grid-line: rgba(255, 255, 255, 0.15);
    --footer-text-main: #ffffff;
    --footer-text-mono: #8a8d9e;
  }

  .blueprint-footer {
    background-color: var(--footer-grid-line);
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1px;
    border-top: 1px solid var(--footer-grid-line);
    border-bottom: 1px solid var(--footer-grid-line);
  }

  .cell {
    background-color: var(--footer-brand-blue);
    padding: 3rem;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--footer-text-main);
  }

  .label-mono {
    font-family: "JetBrains Mono", "Consolas", monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--footer-text-mono);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .label-mono::before {
    content: "";
    width: 8px;
    height: 8px;
    background-color: var(--footer-brand-cyan);
    border-radius: 50%;
    flex: 0 0 auto;
  }

  .cell-brand {
    grid-column: span 6;
  }

  .brand-logo-wrap {
    margin-top: auto;
  }

  .brand-logo {
    width: min(18rem, 75%);
    max-width: 100%;
    height: auto;
    display: block;
  }

  .cell-contact {
    grid-column: span 3;
  }

  .cell-links {
    grid-column: span 3;
  }

  .link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: auto 0 0;
    padding: 0;
  }

  .link-list a {
    color: var(--footer-text-main);
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 600;
    transition: color 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .arrow {
    font-size: 1rem;
    color: var(--footer-brand-cyan);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
    line-height: 1;
  }

  .link-list a:hover {
    color: var(--footer-brand-cyan);
  }

  .link-list a:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .cell-social {
    grid-column: span 2;
    padding: 2.5rem 2rem;
    text-decoration: none;
    color: var(--footer-text-main);
    overflow: hidden;
    transition: color 0.4s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    z-index: 1;
  }

  .cell-social svg {
    width: 2.5rem;
    height: 2.5rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cell-social span {
    font-family: "JetBrains Mono", "Consolas", monospace;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 1px;
  }

  .cell-social::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background-color: var(--footer-brand-cyan);
    z-index: -1;
    transition: height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cell-social:hover {
    color: var(--footer-bg-dark);
  }

  .cell-social:hover svg {
    transform: scale(1.2);
    color: var(--footer-bg-dark);
  }

  .cell-social:hover::before {
    height: 100%;
  }

  .cell-base {
    grid-column: span 9;
    padding: 2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: "JetBrains Mono", "Consolas", monospace;
    font-size: 0.9rem;
    color: var(--footer-text-mono);
    gap: 1rem;
  }

  .time-widget {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--footer-text-main);
    white-space: nowrap;
  }

  .pulsing-dot {
    width: 8px;
    height: 8px;
    background-color: #00ff66;
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex: 0 0 auto;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(0, 255, 102, 0.7);
    }
    70% {
      box-shadow: 0 0 0 6px rgba(0, 255, 102, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(0, 255, 102, 0);
    }
  }

  .cell-up {
    grid-column: span 3;
    padding: 0;
    background-color: var(--footer-brand-cyan);
  }

  .up-btn {
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
    color: var(--footer-bg-dark);
    font-size: 2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .up-btn:hover {
    background-color: #ffffff;
  }

  @media (max-width: 1200px) {
    .cell-brand {
      grid-column: span 12;
    }

    .cell-contact,
    .cell-links {
      grid-column: span 6;
    }

    .cell-social {
      grid-column: span 4;
    }

    .cell-base {
      grid-column: span 8;
    }

    .cell-up {
      grid-column: span 4;
    }
  }

  @media (max-width: 768px) {
    .cell {
      padding: 2rem;
    }

    .cell-contact,
    .cell-links {
      grid-column: span 12;
      border-top: 1px solid var(--footer-grid-line);
    }

    .cell-social {
      grid-column: span 6;
      border-top: 1px solid var(--footer-grid-line);
    }

    .cell-base,
    .cell-up {
      grid-column: span 12;
      border-top: 1px solid var(--footer-grid-line);
    }

    .cell-base {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }

    .cell-up {
      padding: 1rem;
    }

    .up-btn {
      min-height: 4rem;
    }
  }
</style>
