---
/**
 * CTA Section
 * Desktop: 6 floating student photos around a centred heading + glass button.
 * Mobile/tablet: heading + button + 4-photo horizontal strip.
 * Photo positions are percentages of the 1440 × 440 Figma frame (node 103:597).
 */

interface Student {
  src: string;
  /** Tailwind absolute-position classes derived from the Figma frame */
  pos: string;
}

const students: Student[] = [
  { src: 'https://www.figma.com/api/mcp/asset/8cdde401-8d73-4788-a9c3-997ac5c45306', pos: 'left-[6.67%]   top-[5.23%]'   },
  { src: 'https://www.figma.com/api/mcp/asset/e892ca78-52b8-4ff2-97dd-82e3c1419fa4', pos: 'left-[20.83%]  top-[37.05%]'  },
  { src: 'https://www.figma.com/api/mcp/asset/8ac32b70-5cd8-41c9-8a88-c80bc1aabc4d', pos: 'left-[4.44%]   top-[54.55%]'  },
  { src: 'https://www.figma.com/api/mcp/asset/bdfa6a61-1564-41b1-94c1-4ca52f46e48b', pos: 'right-[13.54%] top-[5.23%]'   },
  { src: 'https://www.figma.com/api/mcp/asset/f30d9e3c-c88b-43f8-9725-bd816021d655', pos: 'right-[-3.61%] top-[23.18%]'  },
  { src: 'https://www.figma.com/api/mcp/asset/6ddf4c84-8906-4584-9ff0-4e3e8ab0b215', pos: 'right-[6.39%]  top-[64.55%]'  },
];

const BG_LEFT  = 'https://www.figma.com/api/mcp/asset/5b0218b7-2c6f-4902-8489-b715b300d51c';
const BG_RIGHT = 'https://www.figma.com/api/mcp/asset/1a8f84c5-ff4d-4656-b7fe-9b7f79d8d818';
---

<section
  id="cta"
  class="relative isolate overflow-hidden
         flex flex-col items-center justify-center gap-7
         min-h-[clamp(320px,44vw,440px)] py-12 px-6
         sm:py-16 sm:px-8
         lg:min-h-110 lg:py-20 lg:gap-0 z-1"
>

  {/* ── Decorative background blobs (below everything) ── */}
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">

    {/* Left blob — rotated */}
    <div class="absolute -left-14 top-11.25
                w-[clamp(180px,38vw,544px)] aspect-544/496
                rotate-123 opacity-55 lg:opacity-100">
      <img src={BG_LEFT} alt="" width="294" height="458"
           class="block w-full h-full object-contain"
           loading="lazy" decoding="async" />
    </div>

    {/* Right blob — clamp() on `right` can't be expressed in Tailwind, so one inline style */}
    <div class="absolute top-3.75
                w-[clamp(200px,32vw,455px)] aspect-455/484
                opacity-55 lg:opacity-100"
         style="right: clamp(-143px, -10vw, -56px)">
      <img src={BG_RIGHT} alt="" width="455" height="484"
           class="block w-full h-full object-contain"
           loading="lazy" decoding="async" />
    </div>

  </div>

  {/* ── Floating student photos — desktop only ── */}
  <ul class="hidden lg:block absolute inset-0 pointer-events-none list-none m-0 p-0"
      aria-hidden="true">
    {students.map((s) => (
      <li class={`absolute
                  w-[clamp(100px,10vw,144px)] h-[clamp(100px,10vw,144px)]
                  rounded-[50px] overflow-hidden
                  shadow-[0_0_8.2px_0_#4444b2] bg-[rgba(96,96,195,0.4)]
                  ${s.pos}`}>
        <img src={s.src} alt="" width="144" height="144"
             class="w-full h-full object-cover object-top"
             loading="lazy" decoding="async" />
      </li>
    ))}
  </ul>

  {/* ── Primary content ── */}
  <div class="relative z-10 flex flex-col items-center gap-5 max-w-xl text-center">

    <h2 class="font-['Poppins',sans-serif] font-bold text-[#4242a5]
               text-[clamp(1.75rem,5vw,3rem)] leading-[1.3] m-0">
      Preparado para dar um salto<br />na sua carreira ?
    </h2>

    <a href="#contato"
       class="inline-flex items-center justify-center
              min-w-38.5 h-12.75 px-8
              rounded-[40px] bg-white/18
              shadow-[0_0_16.1px_-4px_#4242a5]
              text-[#4242a5] font-['Poppins',sans-serif] font-bold text-sm
              no-underline whitespace-nowrap leading-none
              transition-[background-color,box-shadow,transform] duration-200 ease-out
              hover:bg-white/32 hover:-translate-y-0.5
              hover:shadow-[0_0_24px_-2px_#4242a5]
              focus-visible:outline-2 focus-visible:outline-[#4242a5]
              focus-visible:outline-offset-3 focus-visible:shadow-[0_0_24px_-2px_#4242a5]
              motion-reduce:transition-none">
      Fale conosco
    </a>

  </div>

  {/* ── Photo strip — mobile / tablet only ── */}
  <ul class="flex lg:hidden flex-nowrap justify-center gap-2 list-none m-0 p-0"
      aria-hidden="true">
    {students.slice(0, 4).map((s) => (
      <li class="shrink-0
                 w-[clamp(60px,16vw,84px)] h-[clamp(60px,16vw,84px)]
                 rounded-[18px] overflow-hidden
                 shadow-[0_0_6px_0_rgba(68,68,178,0.5)] bg-[rgba(96,96,195,0.4)]">
        <img src={s.src} alt="" width="80" height="80"
             class="w-full h-full object-cover object-top"
             loading="lazy" decoding="async" />
      </li>
    ))}
  </ul>

</section>
