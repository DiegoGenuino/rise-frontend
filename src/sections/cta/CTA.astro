---
import StudentImage1 from "../../assets/images/cta/student-image-1.png"
import StudentImage2 from "../../assets/images/cta/student-image-2.png"
import StudentImage3 from "../../assets/images/cta/student-image-3.png"
import StudentImage4 from "../../assets/images/cta/student-image-4.png"
import StudentImage5 from "../../assets/images/cta/student-image-5.png"
import StudentImage6 from "../../assets/images/cta/student-image-6.png"

import LeftVector from "../../assets/icons/cta-vectors/left-vector.svg"
import RightVector from "../../assets/icons/cta-vectors/right-vector.svg"
interface Student {
  src: string;
  pos: string;
}

const students: Student[] = [
  { src: StudentImage1.src, pos: 'left-[6.67%]   top-[5.23%]'   },
  { src: StudentImage2.src, pos: 'left-[20.83%]  top-[37.05%]'  },
  { src: StudentImage3.src, pos: 'left-[4.44%]   top-[54.55%]'  },
  { src: StudentImage4.src, pos: 'right-[13.54%] top-[5.23%]'   },
  { src: StudentImage5.src, pos: 'right-[-3.61%] top-[23.18%]'  },
  { src: StudentImage6.src, pos: 'right-[6.39%]  top-[64.55%]'  },
];

const BG_LEFT  = LeftVector.src;
const BG_RIGHT = RightVector.src;
---

<section
  id="cta"
  class="relative isolate overflow-hidden
         flex flex-col items-center justify-center gap-7
         min-h-[clamp(320px,44vw,440px)] py-12 px-6
         sm:py-16 sm:px-8
         lg:min-h-110 lg:py-20 lg:gap-0 z-1"
>

   <!-- Decorative background blobs (below everything) -->
  <div class="absolute inset-0 -z-10 pointer-events-none min-[300px]:blur-[4px] sm:blur-[6px]"
      style="mask-image: linear-gradient(to bottom, black 0%, black 40%, rgba(0,0,0,0.8) 60%, rgba(0,0,0,0.4) 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, rgba(0,0,0,0.8) 60%, rgba(0,0,0,0.4) 80%, transparent 100%)"
       aria-hidden="true">

    <!-- Left blob — rotated -->
    <div class="absolute -left-14 top-11.25
                w-[clamp(400px,68vw,40vw)] aspect-544/496
                rotate-130 opacity-55 lg:opacity-100 lg:translate-y-12 min-[300px]:-translate-x-30 sm:-translate-x-30 sm:rotate-120 xl:translate-x-0">
      <img src={BG_LEFT} alt="" width="294" height="458"
           class="block w-full h-full object-contain"
           loading="lazy" decoding="async" />
    </div>

    <!-- Right blob — clamp() on `right` can't be expressed in Tailwind, so one inline style  -->
    <div class="absolute top-3.75 rotate-430
                w-[clamp(380px,90vw,40vw)] aspect-455/484
                opacity-55 lg:opacity-100 min-[300px]:translate-x-57  min-[300px]:rotate-110 sm:translate-x-10 sm:rotate-70 xl:-translate-x-20"
         style="right: clamp(-143px, -10vw, -56px)">
      <img src={BG_RIGHT} alt="" width="455" height="484"
           class="block w-full h-full object-contain"
           loading="lazy" decoding="async" />
    </div>
  </div>

  <!-- Floating student photos — desktop only  -->
  <ul class="hidden xl:block absolute inset-0 pointer-events-none list-none m-0 p-0"
      aria-hidden="true">
    {students.map((s) => (
      <li class={`absolute
                  w-[clamp(100px,10vw,144px)] h-[clamp(100px,10vw,144px)]
                  overflow-hidden rounded-[100px] md:rounded-[50px]
                  shadow-[0_0_8.2px_0_#4444b2] bg-[rgba(96,96,195,0.4)]
                  ${s.pos}`}>
        <img src={s.src} alt="" width="144" height="144"
             class="w-full h-full object-cover object-top"
             loading="lazy" decoding="async" />
      </li>
    ))}
  </ul>

  <!-- Primary content -->
  <div class="relative z-10 flex flex-col items-center gap-5 max-w-xl text-center">

    <h2 class="font-['Poppins',sans-serif] font-bold text-[#4242a5]
               text-[clamp(1.75rem,5vw,3rem)] leading-[1.3] m-0">
      Preparado para dar um salto na sua carreira ?
    </h2>

    <a href="#contato"
       class="inline-flex items-center justify-center
              min-w-38.5 h-12.75 px-8
              rounded-[40px] bg-white/18
              shadow-[0_0_16.1px_-4px_#4242a5]
              text-[#4242a5] font-['Poppins',sans-serif] font-bold text-sm
              no-underline whitespace-nowrap leading-none
              transition-[background-color,box-shadow,transform] duration-200 ease-out
              hover:bg-white/32 hover:-translate-y-0.5
              hover:shadow-[0_0_24px_-2px_#4242a5]
              focus-visible:outline-2 focus-visible:outline-[#4242a5]
              focus-visible:outline-offset-3 focus-visible:shadow-[0_0_24px_-2px_#4242a5]
              motion-reduce:transition-none">
      Fale conosco
    </a>

  </div>

  <!-- Photo strip — mobile / tablet only -->
  <ul class="flex lg:mt-10 xl:hidden flex-nowrap justify-center list-none m-0 p-0"
      aria-hidden="true">
    {students.slice(0, 4).map((s, i) => (
      <li class:list={[
            "shrink-0 w-[clamp(30px,9vw,44px)] h-[clamp(30px,9vw,44px)]",
            "rounded-[180px] overflow-hidden",
            "shadow-[0_0_6px_0_rgba(68,68,178,0.5)] bg-[#4242a5cc] transition-colors duration-600 ease-in-out hover:bg-[#4242a5]",
            i > 0 && "-ml-4"
          ]}>
        <img src={s.src} alt="" width="80" height="80"
             class="w-full h-full object-cover object-top"
             loading="lazy" decoding="async" />
      </li>
    ))}
  </ul>

</section>
